rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCircleMember(circleId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));
    }

    function isCircleAdmin(circleId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Profile doc: owner read/write. Subscription field must never be set by client.
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
                   && !('subscription' in request.resource.data);

      // ── habits subcollection ──────────────────────────────────────────
      match /habits/{habitId} {
        allow read, write: if isOwner(userId);

        match /entries/{entryId} {
          allow read, write: if isOwner(userId);
        }
      }

      // ── user preferences (synced from all devices via FirestoreUserPreferencesRepository) ──
      match /state/{docId} {
        allow read, write: if isOwner(userId);
      }

      // ── subscription (server-write only via Admin SDK / Cloud Functions) ──
      match /subscription/{docId} {
        allow read:  if isOwner(userId);
        allow write: if false; // All writes come from validateReceipt / webhook Functions
      }

      // ── fruit_portfolio subcollection ──────────────────────────────────────
      match /fruit_portfolio/{fruitId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── inviteCodes ──────────────────────────────────────────────────────
    // Public read for the join flow. All writes go through Admin SDK.
    match /inviteCodes/{code} {
      allow read: if true;
      allow write: if false;
    }

    // ─── purchaseTokens ───────────────────────────────────────────────────
    // Reverse-lookup index mapping Google Play purchase tokens → Firebase UIDs.
    // Written exclusively by validateReceipt / googleNotification via Admin SDK.
    // No client access permitted — this mapping is sensitive.
    match /purchaseTokens/{tokenId} {
      allow read, write: if false;
    }

    // ─── collectionGroup: members ─────────────────────────────────────────
    // Allows listCircles() to query collectionGroup('members').where('userId', ==, uid).
    // Rule must check the userId FIELD (not the document ID) so Firestore can validate
    // the query filter — checking the doc ID would cause PERMISSION_DENIED on the query.
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── circles ──────────────────────────────────────────────────────────
    match /circles/{circleId} {
      allow read: if isCircleMember(circleId);
      allow create: if isSignedIn();
      allow update: if isCircleAdmin(circleId);
      allow delete: if false;

      // members subcollection
      match /members/{userId} {
        allow read: if isCircleMember(circleId);
        allow write: if false; // Admin SDK only
      }

      // gratitudes subcollection
      match /gratitudes/{gratitudeId} {
        allow read: if isCircleMember(circleId);
        // Owner can only flip deleted=true, nothing else
        allow update: if isCircleMember(circleId) &&
                         resource.data.userId == request.auth.uid &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted']) &&
                         request.resource.data.deleted == true;
        allow create, delete: if false;
      }

      // heatmapEntries subcollection — owner writes, any member reads
      match /heatmapEntries/{userId} {
        allow read: if isCircleMember(circleId);
        allow write: if isOwner(userId) && isCircleMember(circleId);
      }

      // sosRequests subcollection — backend writes only
      match /sosRequests/{sosId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // milestones — backend Admin SDK writes only
      match /milestones/{milestoneId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // meta/totals aggregate — backend writes only
      match /meta/{docId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // userSeenGratitude — owner read/write
      match /userSeenGratitude/{userId} {
        allow read, write: if isOwner(userId) && isCircleMember(circleId);
      }

      // sosContacts — owner write, members read
      match /sosContacts/{userId} {
        allow read: if isCircleMember(circleId);
        allow write: if isOwner(userId) && isCircleMember(circleId);
      }

      // prayer_requests — any member can read; all writes via callable (Admin SDK)
      match /prayer_requests/{requestId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // scripture_focus — any member can read; all writes via callable
      match /scripture_focus/{weekId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;

        // reflections subcollection — any member can read; writes via callable
        match /reflections/{reflectionId} {
          allow read: if isCircleMember(circleId);
          allow write: if false;
        }
      }

      // circle_habits — any member can read; create/deactivate via callable
      match /circle_habits/{habitId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;

        // completions — members write their own; any member reads (for aggregation trigger)
        match /completions/{completionId} {
          allow read: if isCircleMember(circleId);
          // Completion ID is deterministic: {userId}_{date}. Client writes their own only.
          allow create: if isCircleMember(circleId) &&
                          request.resource.data.userId == request.auth.uid;
          allow update, delete: if false;
        }

        // daily_summary — any member can read; trigger writes via Admin SDK
        match /daily_summary/{summaryId} {
          allow read: if isCircleMember(circleId);
          allow write: if false;
        }
      }

      // encouragements — recipient reads via callable (privacy masking); writes via callable
      match /encouragements/{encouragementId} {
        allow read: if false; // Always fetched through circleGetEncouragements callable
        allow write: if false;
      }

      // milestone_shares — any member can read; writes via callable
      match /milestone_shares/{shareId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // circle_habit_milestones — auto-generated by trigger; members read only
      match /circle_habit_milestones/{milestoneId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }

      // weekly_pulse — any member can read; writes via callable
      match /weekly_pulse/{weekId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;

        // pulse responses — any member reads via callable (privacy masking); writes via callable
        match /responses/{responseId} {
          allow read: if false; // Always fetched through circleGetPulseResponses callable
          allow write: if false;
        }
      }

      // events — any member can read; create/delete via callable
      match /events/{eventId} {
        allow read: if isCircleMember(circleId);
        allow write: if false;
      }
    }

    // ─── bible_passage_cache ───────────────────────────────────────────────
    // Populated by circleFetchBiblePassage callable. Read-only for all
    // authenticated users (public scripture text, no PII).
    match /bible_passage_cache/{cacheKey} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
